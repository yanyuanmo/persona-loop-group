{
  "name": "persona_benchmark_v1",
  "goal": "Benchmark persona QA with factual, consistency, and style-retention metrics.",
  "dataset": {
    "data": "data/locomo10.json",
    "slice_file": "configs/benchmark/slices/formal.json",
    "max_qa": 20
  },
  "notes": [
    "Run all experiments with --skip-nli disabled at least once for consistency metrics.",
    "Use the same answer model and cache across compared runs.",
    "Run style scoring on each qa_predictions.json using scripts/eval_persona_style.py."
  ],
  "stages": [
    {
      "id": "stage_a_open_book_limited",
      "description": "Open-book with limited history (max-turns=10), compare no persona, continuous, and persona_loop.",
      "common_args": {
        "llm_provider": "openai",
        "llm_model": "qwen2.5-7b-instruct-q4_k_m-00001-of-00002.gguf",
        "llm_base_url": "http://127.0.0.1:8080/v1",
        "persona_cache": "persona_cache/formal_gpt4o_hybrid.json",
        "eval_mode": "open_book",
        "max_turns": 10
      },
      "runs": [
        {
          "id": "a1_no_persona",
          "agent": "continuous",
          "persona_mode": "off",
          "inject_persona_for_all_agents": false,
          "persona_slot_filter": false
        },
        {
          "id": "a2_continuous_hybrid",
          "agent": "continuous",
          "persona_mode": "hybrid",
          "inject_persona_for_all_agents": true,
          "persona_slot_filter": true
        },
        {
          "id": "a3_persona_loop_hybrid",
          "agent": "persona_loop",
          "persona_mode": "hybrid",
          "inject_persona_for_all_agents": false,
          "persona_slot_filter": false,
          "loop_interval": 7,
          "loop_retrieval_topk": 1,
          "loop_recent_turns": 1,
          "loop_persona_facts": 8,
          "loop_max_corrections": 1
        }
      ]
    },
    {
      "id": "stage_b_memory_only",
      "description": "Closed-book-like setting (memory_only) to test reliance on persona memory.",
      "common_args": {
        "llm_provider": "openai",
        "llm_model": "qwen2.5-7b-instruct-q4_k_m-00001-of-00002.gguf",
        "llm_base_url": "http://127.0.0.1:8080/v1",
        "persona_cache": "persona_cache/formal_gpt4o_hybrid.json",
        "eval_mode": "memory_only",
        "retrieval_topk": 3
      },
      "runs": [
        {
          "id": "b1_no_persona",
          "agent": "continuous",
          "persona_mode": "off",
          "inject_persona_for_all_agents": false,
          "persona_slot_filter": false
        },
        {
          "id": "b2_continuous_hybrid",
          "agent": "continuous",
          "persona_mode": "hybrid",
          "inject_persona_for_all_agents": true,
          "persona_slot_filter": false
        },
        {
          "id": "b3_continuous_hybrid_slot_filter",
          "agent": "continuous",
          "persona_mode": "hybrid",
          "inject_persona_for_all_agents": true,
          "persona_slot_filter": true,
          "persona_slot_filter_min_facts": 4
        }
      ]
    },
    {
      "id": "stage_c_consistency_and_style",
      "description": "Add consistency and style scoring on selected best runs.",
      "steps": [
        "Re-run best 2 configurations from stage A/B with --skip-nli disabled.",
        "Compute persona style metrics using scripts/eval_persona_style.py.",
        "Report combined table: f1, nli_entailment_gold, persona_pcs, psrs, psrs_weighted_by_f1."
      ]
    }
  ],
  "report": {
    "primary_metrics": [
      "f1",
      "em",
      "nli_entailment_gold",
      "nli_contradiction_gold",
      "persona_pcs",
      "psrs",
      "psrs_weighted_by_f1"
    ],
    "required_outputs": [
      "qa_metrics.json",
      "qa_predictions.json",
      "style_metrics.json",
      "style_rows.json"
    ]
  }
}
